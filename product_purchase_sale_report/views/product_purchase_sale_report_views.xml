<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- LIST VIEW -->
    <record id="view_product_purchase_sale_report_list" model="ir.ui.view">
        <field name="name">product.purchase.sale.report.list</field>
        <field name="model">product.purchase.sale.report</field>
        <field name="arch" type="xml">
            <list string="Product Purchase &amp; Sale Report"
                  create="false" edit="false" delete="false"
                  decoration-success="transaction_type == 'sale'"
                  decoration-info="transaction_type == 'purchase'">

                <field name="date_str"           string="Date"             optional="show"/>
                <field name="transaction_type"   string="Type"             widget="badge"
                       decoration-success="transaction_type == 'sale'"
                       decoration-primary="transaction_type == 'purchase'"/>
                <field name="product_id"         string="Product"/>
                <field name="categ_id"           string="Category"/>
                <field name="warehouse_id"       string="Warehouse"        optional="show"/>

                <!-- PURCHASE columns -->
                <field name="vendor_id"          string="Vendor"           optional="show"/>
                <field name="purchase_order_name" string="Purchase Order"  optional="show"/>
                <field name="bill_number"        string="Bill Number"      optional="show"/>
                <field name="receipt_number"     string="Receipt Number"   optional="show"/>

                <!-- SALE columns -->
                <field name="customer_id"        string="Customer"         optional="show"/>
                <field name="sale_order_name"    string="Sale Order"       optional="show"/>
                <field name="invoice_number"     string="Invoice Number"   optional="show"/>
                <field name="delivery_number"    string="Delivery Number"  optional="show"/>

                <!-- Qty &amp; Price -->
                <field name="uom_id"             string="UoM"              optional="show"/>
                <field name="qty"                string="Quantity"         sum="Total Qty"/>
                <field name="unit_price"         string="Unit Rate"
                       widget="monetary"
                       options="{'currency_field': 'currency_id'}"/>
                <field name="price_subtotal"     string="Subtotal"
                       widget="monetary"
                       options="{'currency_field': 'currency_id'}"
                       sum="Total"/>
                <field name="currency_id"        column_invisible="1"/>
                <field name="company_id"         optional="hide"/>
                <!-- hidden: needed for ordering -->
                <field name="transaction_date"   column_invisible="1"/>
            </list>
        </field>
    </record>

    <!-- PIVOT VIEW -->
    <record id="view_product_purchase_sale_report_pivot" model="ir.ui.view">
        <field name="name">product.purchase.sale.report.pivot</field>
        <field name="model">product.purchase.sale.report</field>
        <field name="arch" type="xml">
            <pivot string="Product Purchase &amp; Sale Report">
                <field name="product_id" type="row"/>
                <field name="transaction_type" type="col"/>
                <field name="price_subtotal" type="measure"/>
                <field name="qty" type="measure"/>
                <field name="unit_price" type="measure"/>
            </pivot>
        </field>
    </record>

    <!-- GRAPH VIEW -->
    <record id="view_product_purchase_sale_report_graph" model="ir.ui.view">
        <field name="name">product.purchase.sale.report.graph</field>
        <field name="model">product.purchase.sale.report</field>
        <field name="arch" type="xml">
            <graph string="Product Purchase &amp; Sale Report" type="bar" stacked="1">
                <field name="product_id" type="row"/>
                <field name="price_subtotal" type="measure"/>
            </graph>
        </field>
    </record>

    <!-- ACTION — full window -->
    <record id="action_product_purchase_sale_report" model="ir.actions.act_window">
        <field name="name">Purchase &amp; Sale Report</field>
        <field name="res_model">product.purchase.sale.report</field>
        <field name="view_mode">list,pivot,graph</field>
        <field name="target">current</field>
        <field name="context">{}</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                No transactions found!
            </p>
            <p>
                This report shows all purchase bills with receipt numbers
                and sales invoices with delivery numbers per product,
                including unit rates.
            </p>
        </field>
        <field name="view_ids" eval="[
            (5, 0, 0),
            (0, 0, {'view_mode': 'list',  'view_id': ref('view_product_purchase_sale_report_list')}),
            (0, 0, {'view_mode': 'pivot', 'view_id': ref('view_product_purchase_sale_report_pivot')}),
            (0, 0, {'view_mode': 'graph', 'view_id': ref('view_product_purchase_sale_report_graph')}),
        ]"/>
    </record>

</odoo>