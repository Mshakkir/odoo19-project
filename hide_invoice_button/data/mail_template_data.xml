<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="0">

        <!--
        FIX: Auto-fill "To" field with customer email when sending invoice.
        Sets partner_to on the Invoice Sending template so Odoo pre-populates
        the recipient field in the Send dialog.
        -->
        <record id="account.email_template_edi_invoice" model="mail.template">
            <field name="partner_to">{{ object.partner_id.id }}</field>
        </record>

    </data>
</odoo>
