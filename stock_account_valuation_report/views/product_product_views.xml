<?xml version="1.0" encoding="utf-8" ?>
<odoo>

    <!-- Wizard form: date picker for "Valuation at Date" -->
    <record id="view_stock_valuation_history" model="ir.ui.view">
        <field name="name">Dual Valuation Report at Date</field>
        <field name="model">stock.valuation.history</field>
        <field name="arch" type="xml">
            <form string="Choose your date">
                <group>
                    <field name="inventory_datetime" />
                </group>
                <button
                    name="open_at_date"
                    string="Confirm"
                    type="object"
                    class="btn-primary"
                />
                <button string="Cancel" class="btn-secondary" special="cancel" />
            </form>
        </field>
    </record>

    <!-- Wizard action – opens as a dialog (target new) -->
    <record id="history_valuation_action" model="ir.actions.act_window">
        <field name="name">Valuation at Date</field>
        <field name="res_model">stock.valuation.history</field>
        <field name="view_mode">form</field>
        <field name="view_id" ref="view_stock_valuation_history" />
        <field name="target">new</field>
    </record>

    <!-- Menu item: opens the standard Stock Valuation (SVL) list from stock_account -->
    <menuitem
        id="menu_dual_valuation"
        name="Stock Valuation"
        parent="stock.menu_warehouse_report"
        sequence="120"
        action="stock_account.action_stock_account_open_quants"
    />

</odoo>
