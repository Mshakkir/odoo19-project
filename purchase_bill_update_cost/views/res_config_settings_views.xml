<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="res_config_settings_view_purchase_bill_cost" model="ir.ui.view">
        <field name="name">res.config.settings.view.purchase.bill.cost</field>
        <field name="model">res.config.settings</field>
        <field name="inherit_id" ref="base.res_config_settings_view_form"/>
        <field name="arch" type="xml">
            <xpath expr="//form" position="inside">
                <app string="Vendor Bill Cost" name="purchase_bill_update_cost"
                     groups="account.group_account_manager">
                    <block title="Product Cost Update">
                        <setting string="Update Product Cost on Bill Confirmation"
                                 help="When a vendor bill is confirmed/posted, automatically update the product Standard Price with the bill unit price.">
                            <field name="auto_update_cost_on_bill" widget="boolean_toggle"/>
                        </setting>
                    </block>
                </app>
            </xpath>
        </field>
    </record>
</odoo>