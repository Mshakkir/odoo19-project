<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!--
        REPLACES both:
          - the old product_template.xml (warehouse/total price columns)
          - the new product_views.xml (cost hiding)
        Put this file as views/product_views.xml and DELETE any other
        view XML file that touches product.template list/form.
    -->

    <!-- ============================================================
         LIST VIEW — all custom columns + cost hiding in ONE view
    ============================================================ -->
    <record id="product_template_list_custom" model="ir.ui.view">
        <field name="name">product.template.list.custom</field>
        <field name="model">product.template</field>
        <field name="inherit_id" ref="product.product_template_tree_view"/>
        <field name="arch" type="xml">

            <!-- 1. Created Date column BEFORE Product Name -->
            <field name="name" position="before">
                <field name="x_created_date_display"
                       string="Created Date"
                       readonly="1"
                       optional="show"
                       width="90px"/>
            </field>

            <!-- 2. Widths on existing base columns -->
            <field name="name" position="attributes">
                <attribute name="width">200px</attribute>
            </field>
            <field name="default_code" position="attributes">
                <attribute name="width">120px</attribute>
            </field>
            <field name="list_price" position="attributes">
                <attribute name="width">100px</attribute>
            </field>
            <field name="uom_id" position="attributes">
                <attribute name="width">80px</attribute>
            </field>

            <!-- 3. Hide Cost (standard_price) column from restricted group -->
            <field name="standard_price" position="attributes">
                <attribute name="width">100px</attribute>
                <attribute name="groups">!hide_cost_fields.group_hide_cost</attribute>
            </field>

            <!-- 4. Warehouse stock columns AFTER Internal Reference -->
            <field name="default_code" position="after">
                <field name="qty_fyh_stock" string="FYH/Stock"   optional="show" sum="FYH/Stock"   width="90px"/>
                <field name="qty_bld_stock" string="BLD/Stock"   optional="show" sum="BLD/Stock"   width="90px"/>
                <field name="qty_dmm_stock" string="DMM-1/Stock" optional="show" sum="DMM-1/Stock" width="100px"/>
            </field>

            <!-- 5. On Hand width -->
            <field name="qty_available" position="attributes">
                <attribute name="width">90px</attribute>
            </field>

            <!-- 6. Total price columns AFTER On Hand -->
            <!--    total_sales_price: visible to all -->
            <!--    total_cost_price:  hidden from restricted group -->
            <field name="qty_available" position="after">
                <field name="total_sales_price"
                       string="Total Sales Price"
                       optional="show"
                       sum="Total Sales Price"
                       width="120px"/>
                <field name="total_cost_price"
                       string="Total Cost Price"
                       optional="show"
                       sum="Total Cost Price"
                       width="120px"
                       groups="!hide_cost_fields.group_hide_cost"/>
            </field>

        </field>
    </record>

    <!-- ============================================================
         FORM VIEW — hide Cost field from restricted group
    ============================================================ -->
    <record id="product_template_form_hide_cost" model="ir.ui.view">
        <field name="name">product.template.form.hide.cost</field>
        <field name="model">product.template</field>
        <field name="inherit_id" ref="product.product_template_form_view"/>
        <field name="arch" type="xml">

            <field name="standard_price" position="attributes">
                <attribute name="groups">!hide_cost_fields.group_hide_cost</attribute>
            </field>

        </field>
    </record>

</odoo>







