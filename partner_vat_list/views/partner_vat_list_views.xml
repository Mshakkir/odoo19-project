<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- ============================================================
         Inline Tree view used inside the partner form
         ============================================================ -->
    <record id="view_partner_vat_line_tree" model="ir.ui.view">
        <field name="name">partner.vat.line.tree</field>
        <field name="model">partner.vat.line</field>
        <field name="arch" type="xml">
            <list string="VAT / Tax Rules" editable="bottom">
                <field name="sequence" widget="handle"/>
                <field name="tax_type" widget="badge"
                       decoration-success="tax_type == 'sale'"
                       decoration-warning="tax_type == 'purchase'"/>
                <field name="tax_id" 
                       domain="[('type_tax_use', '=', tax_type), ('active', '=', True)]"
                       options="{'no_create': True}"
                       required="1"/>
                <field name="tax_amount" string="Tax %" readonly="1"/>
                <field name="product_id" optional="show"
                       options="{'no_create': True}"/>
                <field name="product_category_id" optional="show"
                       options="{'no_create': True}"/>
                <field name="active" optional="hide"/>
            </list>
        </field>
    </record>

    <!-- ============================================================
         Standalone form view for partner.vat.line
         ============================================================ -->
    <record id="view_partner_vat_line_form" model="ir.ui.view">
        <field name="name">partner.vat.line.form</field>
        <field name="model">partner.vat.line</field>
        <field name="arch" type="xml">
            <form string="VAT / Tax Rule">
                <sheet>
                    <group>
                        <group string="Tax Information">
                            <field name="tax_type"/>
                            <field name="tax_id"
                                   domain="[('type_tax_use', '=', tax_type), ('active', '=', True)]"
                                   options="{'no_create': True}"
                                   required="1"/>
                            <field name="tax_amount" readonly="1"/>
                        </group>
                        <group string="Scope (optional)">
                            <field name="product_id"
                                   options="{'no_create': True}"
                                   help="Leave blank to apply to all products"/>
                            <field name="product_category_id"
                                   options="{'no_create': True}"
                                   help="Leave blank to apply to all categories"/>
                            <field name="sequence"/>
                            <field name="active"/>
                        </group>
                    </group>
                    <div class="alert alert-info" role="alert">
                        <strong>Priority:</strong>
                        Specific Product &gt; Product Category &gt; All Products (generic).
                        The first matching rule is used when a product is added to an order or invoice.
                    </div>
                </sheet>
            </form>
        </field>
    </record>

</odoo>
