<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="sale_order_send_wizard_form" model="ir.ui.view">
        <field name="name">sale.order.send.wizard.form</field>
        <field name="model">sale.order.send.wizard</field>
        <field name="arch" type="xml">
            <form string="Send">
                <field name="order_id" invisible="1"/>

                <!-- Sending method checkboxes (matching invoice style) -->
                <div class="m-0" id="send_options">
                    <div class="d-flex gap-3 mb-2">
                        <label class="fw-bold">
                            <input type="checkbox" checked="1" disabled="1" class="me-1"/>
                            by Email
                        </label>
                    </div>
                </div>

                <!-- Mail composer -->
                <group>
                    <label for="mail_partner_ids" string="To"/>
                    <div>
                        <field
                            name="mail_partner_ids"
                            widget="many2many_tags_email"
                            placeholder="Add contacts to notify..."
                            options="{'no_quick_create': True}"
                            required="1"
                            context="{'show_email': True, 'form_view_ref': 'base.view_partner_simple_form'}"
                        />
                    </div>
                    <field name="subject" placeholder="Subject..." required="1"/>
                </group>

                <field
                    name="body"
                    class="oe-bordered-editor"
                    widget="html_mail"
                />

                <footer>
                    <button
                        string="Send"
                        name="action_send"
                        type="object"
                        class="btn-primary"
                        data-hotkey="q"
                    />
                    <button
                        string="Discard"
                        name="action_discard"
                        type="object"
                        class="btn-secondary"
                        data-hotkey="x"
                    />
                    <field
                        name="template_id"
                        widget="mail_composer_template_selector"
                        invisible="1"
                    />
                </footer>
            </form>
        </field>
    </record>

</odoo>
