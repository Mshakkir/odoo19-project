<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="view_sales_estimation_status_wizard_form" model="ir.ui.view">
        <field name="name">sales.estimation.status.wizard.form</field>
        <field name="model">sales.estimation.status.wizard</field>
        <field name="arch" type="xml">
            <form string="Sales Estimation Status Register">
                <sheet>

                    <!-- Type + Filter dropdowns -->
                    <group>
                        <group>
                            <field name="estimation_type" string="Type"/>
                        </group>
                        <group>
                            <field name="date_filter" string="Filter"/>
                        </group>
                    </group>

                    <!-- Options -->
                    <group string="Options">
                        <group>
                            <field name="form_type"  string="Form Type"/>
<!--                            <field name="bill_mode"  string="Bill Mode"/>-->
                            <field name="partner_id" string="Party"/>
                        </group>
<!--                        <group>-->
<!--                            <field name="by_confirmed_status" string="By Confirmed Status"/>-->
<!--                            <field name="confirmed"-->
<!--                                   string="Confirmed"-->
<!--                                   invisible="not by_confirmed_status"/>-->
<!--                            <field name="by_cancelled_status" string="By Cancelled Status"/>-->
<!--                            <field name="cancelled"-->
<!--                                   string="Cancelled"-->
<!--                                   invisible="not by_cancelled_status"/>-->
<!--                        </group>-->
                    </group>

                    <!-- Date period quick-select (horizontal radio) -->
                    <group string="Date Period">
                        <field name="date_filter"
                               widget="radio"
                               string="Quick Select"
                               options="{'horizontal': true}"
                               nolabel="1"/>
                    </group>

                    <!-- From / To -->
                    <group>
                        <group>
                            <field name="date_from" string="From" required="1"/>
                        </group>
                        <group>
                            <field name="date_to"   string="To"   required="1"/>
                        </group>
                    </group>

                    <!-- Multi-company -->
                    <field name="company_id"
                           groups="base.group_multi_company"
                           invisible="1"/>

                    <!-- Use Ledger Currency -->
<!--                    <group>-->
<!--                        <field name="use_ledger_currency" string="Use Ledger Currency"/>-->
<!--                    </group>-->

                </sheet>

                <footer>
                    <button name="action_show_report"
                            string="Show Report (F5)"
                            type="object"
                            class="btn-primary"/>
                    <button name="action_show_details"
                            string="Show Details"
                            type="object"
                            class="btn-info"/>
                    <button name="action_export_excel"
                            string="Export Excel"
                            type="object"
                            class="btn-success"/>
                    <button string="Exit"
                            class="btn-danger"
                            special="cancel"/>
                </footer>
            </form>
        </field>
    </record>

    <!-- Wizard window action -->
    <record id="action_sales_estimation_status_wizard" model="ir.actions.act_window">
        <field name="name">Sales Estimation Status Register</field>
        <field name="res_model">sales.estimation.status.wizard</field>
        <field name="view_mode">form</field>
        <field name="target">new</field>
    </record>

    <!-- ══════════════════════════════════════════════════════════════
         MENU STRATEGY:
         Try to attach under sales_register root first (sequence=2).
         We also create our OWN root menu as a safe fallback so the
         item always appears even if sales_register root ID differs.
    ══════════════════════════════════════════════════════════════ -->

    <!-- Safe standalone root under the Sales app -->
  <!-- ── Menu Item ────────────────────────────────────────────────────────── -->
    <!-- Placed under the existing "Sales Register" root from the sales_register module -->
    <menuitem id="menu_sales_estimation_status_report"
              name="Sales Estimation Report Status"
              parent="sales_register.menu_sales_register_root"
              action="action_sales_estimation_status_wizard"
              sequence="2"/>

</odoo>