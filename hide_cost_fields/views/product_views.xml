<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!--
        Hides Cost and/or Sales Price fields based on group membership:
          - group_hide_cost        → hides standard_price, total_cost_price
          - group_hide_sales_price → hides list_price, total_sales_price
        Add users to the relevant group in Settings > Users & Companies > Groups.
    -->

    <!-- ============================================================
         LIST VIEW — hide cost and/or sales price columns
    ============================================================ -->
    <record id="product_template_list_hide_prices" model="ir.ui.view">
        <field name="name">product.template.list.hide.prices</field>
        <field name="model">product.template</field>
        <field name="inherit_id" ref="product.product_template_tree_view"/>
        <field name="arch" type="xml">

            <!-- Hide Cost column from restricted group -->
            <field name="standard_price" position="attributes">
                <attribute name="groups">!hide_cost_fields.group_hide_cost</attribute>
            </field>

            <!-- Hide Total Cost Price column from restricted group -->
            <field name="total_cost_price" position="attributes">
                <attribute name="groups">!hide_cost_fields.group_hide_cost</attribute>
            </field>

            <!-- Hide Sales Price column from restricted group -->
            <field name="list_price" position="attributes">
                <attribute name="groups">!hide_cost_fields.group_hide_sales_price</attribute>
            </field>

            <!-- Hide Total Sales Price column from restricted group -->
            <field name="total_sales_price" position="attributes">
                <attribute name="groups">!hide_cost_fields.group_hide_sales_price</attribute>
            </field>

        </field>
    </record>

    <!-- ============================================================
         FORM VIEW — hide cost and/or sales price fields
    ============================================================ -->
    <record id="product_template_form_hide_prices" model="ir.ui.view">
        <field name="name">product.template.form.hide.prices</field>
        <field name="model">product.template</field>
        <field name="inherit_id" ref="product.product_template_form_view"/>
        <field name="arch" type="xml">

            <!-- Hide Cost field from restricted group -->
            <field name="standard_price" position="attributes">
                <attribute name="groups">!hide_cost_fields.group_hide_cost</attribute>
            </field>

            <!-- Hide Sales Price field from restricted group -->
            <field name="list_price" position="attributes">
                <attribute name="groups">!hide_cost_fields.group_hide_sales_price</attribute>
            </field>

        </field>
    </record>

</odoo>
