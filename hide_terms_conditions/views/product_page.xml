<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!--
        Hide Terms and Conditions from product page.
        Source: templates.xml:2530 - standalone template called via t-call
        Strategy: inherit and replace entire content with empty string
    -->
    <template id="hide_product_terms_and_conditions"
              inherit_id="website_sale.product_terms_and_conditions"
              name="Hide Terms and Conditions">
        <xpath expr="//small" position="replace"/>
    </template>

</odoo>