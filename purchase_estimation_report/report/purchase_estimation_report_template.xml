<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <template id="report_purchase_estimation_document">
        <t t-call="web.html_container">
            <t t-foreach="docs" t-as="wizard">
                <t t-call="web.external_layout">
                    <div class="page">
                        <!-- Report Title -->
                        <div class="row mb-3">
                            <div class="col-12 text-center">
                                <h4><strong>Purchase Estimation Balance Register</strong></h4>
                                <p class="mb-1">
                                    <t t-if="wizard.vendor_id">
                                        Vendor: <strong><t t-esc="wizard.vendor_id.name"/></strong> &amp;nbsp;|&amp;nbsp;
                                    </t>
                                    Period: <strong><t t-esc="wizard.date_from"/></strong>
                                    &amp;nbsp;To&amp;nbsp;
                                    <strong><t t-esc="wizard.date_to"/></strong>
                                </p>
                            </div>
                        </div>

                        <!-- Data Table -->
                        <table class="table table-sm table-bordered o_main_table" style="font-size:11px;">
                            <thead>
                                <tr style="background-color:#4472C4; color:#ffffff;">
                                    <th>Vno</th>
                                    <th>Date</th>
                                    <th>Vendor</th>
                                    <th>Address</th>
                                    <th>Cell No</th>
                                    <th>Narration</th>
                                    <th class="text-right">Net Amount</th>
                                    <th>Confirm Date</th>
                                    <th>Required Date</th>
                                </tr>
                            </thead>
                            <tbody>
                                <t t-foreach="wizard.line_ids" t-as="line">
                                    <tr>
                                        <td><t t-esc="line.vno"/></td>
                                        <td><t t-esc="line.date"/></td>
                                        <td><t t-esc="line.customer"/></td>
                                        <td><t t-esc="line.address"/></td>
                                        <td><t t-esc="line.cell_no"/></td>
                                        <td><t t-esc="line.narration"/></td>
                                        <td class="text-right">
                                            <t t-esc="'{:,.2f}'.format(line.net_amount)"/>
                                        </td>
                                        <td><t t-esc="line.confirm_date or ''"/></td>
                                        <td><t t-esc="line.required_date or ''"/></td>
                                    </tr>
                                </t>
                            </tbody>
                            <tfoot>
                                <tr style="background-color:#D9E1F2; font-weight:bold;">
                                    <td colspan="6" class="text-right">Total:</td>
                                    <td class="text-right">
                                        <t t-esc="'{:,.2f}'.format(sum(wizard.line_ids.mapped('net_amount')))"/>
                                    </td>
                                    <td colspan="2"/>
                                </tr>
                            </tfoot>
                        </table>
                    </div>
                </t>
            </t>
        </t>
    </template>

</odoo>