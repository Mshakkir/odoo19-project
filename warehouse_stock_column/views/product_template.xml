<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- LIST VIEW: Created Date column before Product Name -->
    <record id="product_template_list_created_date" model="ir.ui.view">
        <field name="name">product.template.list.created_date</field>
        <field name="model">product.template</field>
        <field name="inherit_id" ref="product.product_template_tree_view"/>
        <field name="arch" type="xml">
            <field name="name" position="before">
                <field
                    name="x_created_date_display"
                    string="Created Date"
                    readonly="1"
                    optional="show"
                    width="90px"
                />
            </field>
        </field>
    </record>

    <!-- LIST VIEW: Warehouse stock + total price columns -->
    <record id="product_template_list_warehouse_columns" model="ir.ui.view">
        <field name="name">product.template.list.warehouse.columns</field>
        <field name="model">product.template</field>
        <field name="inherit_id" ref="product.product_template_tree_view"/>
        <field name="arch" type="xml">

            <field name="name" position="attributes">
                <attribute name="width">200px</attribute>
            </field>
            <field name="default_code" position="attributes">
                <attribute name="width">120px</attribute>
            </field>
            <field name="list_price" position="attributes">
                <attribute name="width">100px</attribute>
            </field>
            <field name="standard_price" position="attributes">
                <attribute name="width">100px</attribute>
                <attribute name="groups">base.group_system,product_location_column.group_can_see_cost_price</attribute>
            </field>
            <field name="uom_id" position="attributes">
                <attribute name="width">80px</attribute>
            </field>
            <field name="qty_available" position="attributes">
                <attribute name="width">90px</attribute>
            </field>

            <!-- Warehouse stock columns after Internal Reference -->
            <field name="default_code" position="after">
                <field name="qty_fyh_stock"  string="FYH/Stock"   optional="show" sum="FYH/Stock"   width="90px"/>
                <field name="qty_bld_stock"  string="BLD/Stock"   optional="show" sum="BLD/Stock"   width="90px"/>
                <field name="qty_dmm_stock"  string="DMM-1/Stock" optional="show" sum="DMM-1/Stock" width="100px"/>
            </field>

            <!-- Total price columns after On Hand -->
            <field name="qty_available" position="after">
                <field name="total_sales_price" string="Total Sales Price" optional="show" sum="Total Sales Price" width="120px"/>
                <field name="total_cost_price"  string="Total Cost Price"  optional="show" sum="Total Cost Price"  width="120px"
                       groups="base.group_system,product_location_column.group_can_see_cost_price"/>
            </field>

        </field>
    </record>

    <!-- CUSTOM CSS: Center all columns in product list view -->
    <record id="product_template_list_center_css" model="ir.ui.view">
        <field name="name">product.template.list.center.css</field>
        <field name="model">product.template</field>
        <field name="inherit_id" ref="product.product_template_tree_view"/>
        <field name="arch" type="xml">
            <xpath expr="//list" position="attributes">
                <attribute name="class">o_list_view_center_columns</attribute>
            </xpath>
        </field>
    </record>

</odoo>






