<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <!--
            Place Purchase Sales Comparison directly under the Inventory app root.
            We do NOT create a new parent menu (which would appear as a sidebar app).
            Instead we add it as a direct child of stock.menu_stock_root so it
            appears as a top-level menu item INSIDE the Inventory app.
        -->
        <menuitem
            id="menu_purchase_sales_comparison_report"
            name="Purchase Sales Comparison"
            parent="stock.menu_stock_root"
            action="purchase_sales_comparison_report.action_purchase_sales_comparison_wizard"
            sequence="99"
            groups="stock.group_stock_user,stock.group_stock_manager"/>
    </data>
</odoo>