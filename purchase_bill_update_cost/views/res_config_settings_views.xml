<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="res_config_settings_view_purchase_bill_cost" model="ir.ui.view">
        <field name="name">res.config.settings.view.purchase.bill.cost</field>
        <field name="model">res.config.settings</field>
        <field name="inherit_id" ref="purchase.res_config_settings_view_form"/>
        <field name="arch" type="xml">
            <!-- Adds our toggle inside the Purchase section of Settings -->
            <xpath expr="//div[@id='purchase']" position="inside">
                <div class="col-12 col-lg-6 o_setting_box" id="auto_update_cost_on_bill_box">
                    <div class="o_setting_left_pane">
                        <field name="auto_update_cost_on_bill" widget="boolean_toggle"/>
                    </div>
                    <div class="o_setting_right_pane">
                        <label for="auto_update_cost_on_bill"/>
                        <div class="text-muted">
                            Automatically update the product's cost price when a
                            vendor bill is confirmed.
                        </div>
                    </div>
                </div>
            </xpath>
        </field>
    </record>
</odoo>
