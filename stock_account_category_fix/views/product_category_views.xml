<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>

        <record id="product_category_form_view_stock_account_fix" model="ir.ui.view">
            <field name="name">product.category.form.stock.account.fix</field>
            <field name="model">product.category</field>
            <field name="inherit_id" ref="product.product_category_form_view"/>
            <field name="arch" type="xml">
                <xpath expr="//group[@name='account_properties']" position="after">
                    <group
                        name="account_stock_properties"
                        string="Account Stock Properties"
                        invisible="property_valuation != 'real_time'">
                        <field
                            name="property_stock_valuation_account_id"
                            domain="[('company_id', 'in', [current_company_id, False])]"/>
                        <field name="property_stock_journal"/>
                        <field
                            name="property_stock_account_input_categ_id"
                            domain="[('company_id', 'in', [current_company_id, False])]"
                            string="Stock Input Account"/>
                        <field
                            name="property_stock_account_output_categ_id"
                            domain="[('company_id', 'in', [current_company_id, False])]"
                            string="Stock Output Account"/>
                    </group>
                    <group invisible="property_valuation != 'real_time'">
                        <div colspan="2">
                            <button
                                name="%(stock_account.action_stock_account_config)d"
                                type="action"
                                string="Set other input/output accounts on specific locations"
                                class="btn-link"/>
                        </div>
                    </group>
                </xpath>
            </field>
        </record>

    </data>
</odoo>
