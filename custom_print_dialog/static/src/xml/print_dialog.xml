<?xml version="1.0" encoding="utf-8"?>
<templates xml:space="preserve">

    <t t-name="custom_print_dialog.PrintPreviewDialog">
        <!--
            size="xl"  → wide enough for side-by-side panels
            footer="false" → we control our own footer buttons inside the settings panel
        -->
        <Dialog t-att-title="dialogTitle" size="'xl'" contentClass="'cpd-dialog-content p-0'" footer="false" onClose.bind="onClose">

            <div class="cpd-body d-flex" style="height: 82vh; overflow: hidden;">

                <!-- ══════════════════════════════════════════════════════════
                     LEFT PANEL — PDF preview rendered by the browser
                     Uses the exact same PDF that Odoo's Print button produces.
                ═══════════════════════════════════════════════════════════ -->
                <div class="cpd-preview-panel d-flex flex-column flex-grow-1" style="min-width:0; background:#525659;">

                    <!-- Toolbar strip above the iframe -->
                    <div class="cpd-preview-toolbar d-flex align-items-center px-3 py-2 gap-2" style="background:#3c3f41; color:#ccc; font-size:13px; flex-shrink:0;">
                        <i class="fa fa-file-pdf-o text-danger"/>
                        <span class="fw-semibold">Preview</span>
                        <span class="ms-auto text-muted small" t-if="!state.loading and !state.loadError">
                            PDF Report
                        </span>
                    </div>

                    <!-- Loading state -->
                    <div t-if="state.loading" class="d-flex align-items-center justify-content-center flex-grow-1">
                        <div class="text-center text-white">
                            <i class="fa fa-spinner fa-spin fa-3x mb-3" style="color:#aaa;"/>
                            <p style="color:#ccc;">Generating PDF preview…</p>
                        </div>
                    </div>

                    <!-- Error state -->
                    <div t-elif="state.loadError" class="d-flex align-items-center justify-content-center flex-grow-1">
                        <div class="text-center text-white p-4">
                            <i class="fa fa-exclamation-triangle fa-3x mb-3 text-warning"/>
                            <p>Could not load the PDF preview.</p>
                            <p class="small text-muted mb-3">Make sure the record is posted and a report template exists.</p>
                        </div>
                    </div>

                    <!--
                        The iframe src points to Odoo's standard PDF endpoint.
                        Browsers render PDFs natively inside iframes (same as opening in a tab).
                        The iframe is hidden while loading to avoid a flash.
                    -->
                    <iframe
                        t-ref="previewIframe"
                        t-att-src="pdfPreviewUrl"
                        t-on-load="onIframeLoad"
                        t-on-error="onIframeError"
                        class="cpd-iframe border-0 w-100 flex-grow-1"
                        t-att-style="state.loading ? 'visibility:hidden; height:0;' : 'visibility:visible; height:100%;'"
                        title="PDF Preview"
                    />
                </div>

                <!-- ══════════════════════════════════════════════════════════
                     RIGHT PANEL — Settings + action buttons
                ═══════════════════════════════════════════════════════════ -->
                <div class="cpd-settings-panel d-flex flex-column border-start" style="width:310px; min-width:280px; background:#fff;">

                    <!-- Settings header -->
                    <div class="cpd-settings-header px-3 py-2 border-bottom" style="background:#f8f9fa; flex-shrink:0;">
                        <span class="fw-bold" style="font-size:14px;">
                            <i class="fa fa-print me-2 text-primary"/>
                            Print
                        </span>
                    </div>

                    <!-- Scrollable settings body -->
                    <div class="cpd-settings-body flex-grow-1 overflow-auto px-3 py-3" style="font-size:13px;">

                        <!-- ── Destination ───────────────────────────────── -->
                        <div class="cpd-group mb-4">
                            <div class="cpd-group-label">Destination</div>
                            <div class="border rounded px-3 py-2 bg-light d-flex align-items-center gap-2">
                                <i class="fa fa-file-pdf-o text-danger"/>
                                <span>Save as PDF</span>
                            </div>
                        </div>

                        <!-- ── Pages ─────────────────────────────────────── -->
                        <div class="cpd-group mb-4">
                            <div class="cpd-group-label">Pages</div>
                            <div class="border rounded bg-white">
                                <!-- All pages -->
                                <label class="cpd-radio-row border-bottom d-flex align-items-center gap-2 px-3 py-2 m-0" style="cursor:pointer;">
                                    <input type="radio"
                                           name="cpd_pages"
                                           value="all"
                                           class="form-check-input m-0 flex-shrink-0"
                                           t-att-checked="state.selectedPages === 'all'"
                                           t-on-change="() => setPages('all')"/>
                                    <span>All</span>
                                </label>
                                <!-- Custom pages -->
                                <label class="cpd-radio-row d-flex align-items-center gap-2 px-3 py-2 m-0" style="cursor:pointer;">
                                    <input type="radio"
                                           name="cpd_pages"
                                           value="custom"
                                           class="form-check-input m-0 flex-shrink-0"
                                           t-att-checked="state.selectedPages === 'custom'"
                                           t-on-change="() => setPages('custom')"/>
                                    <span>Custom</span>
                                </label>
                                <!-- Custom range input -->
                                <div t-if="state.selectedPages === 'custom'" class="px-3 pb-2">
                                    <input type="text"
                                           class="form-control form-control-sm"
                                           placeholder="e.g. 1–3, 5"
                                           t-model="state.customPages"/>
                                </div>
                            </div>
                        </div>

                        <!-- ── Layout ────────────────────────────────────── -->
                        <div class="cpd-group mb-4">
                            <div class="cpd-group-label">Layout</div>
                            <div class="border rounded bg-white">
                                <label class="cpd-radio-row border-bottom d-flex align-items-center gap-2 px-3 py-2 m-0" style="cursor:pointer;">
                                    <input type="radio"
                                           name="cpd_layout"
                                           value="portrait"
                                           class="form-check-input m-0 flex-shrink-0"
                                           t-att-checked="state.layout === 'portrait'"
                                           t-on-change="() => setLayout('portrait')"/>
                                    <i class="fa fa-file-o" style="width:14px;"/>
                                    <span>Portrait</span>
                                </label>
                                <label class="cpd-radio-row d-flex align-items-center gap-2 px-3 py-2 m-0" style="cursor:pointer;">
                                    <input type="radio"
                                           name="cpd_layout"
                                           value="landscape"
                                           class="form-check-input m-0 flex-shrink-0"
                                           t-att-checked="state.layout === 'landscape'"
                                           t-on-change="() => setLayout('landscape')"/>
                                    <i class="fa fa-file-o fa-rotate-90" style="width:14px;"/>
                                    <span>Landscape</span>
                                </label>
                            </div>
                        </div>

                        <!-- ── Copies ────────────────────────────────────── -->
                        <div class="cpd-group mb-3">
                            <div class="cpd-group-label">Copies</div>
                            <input type="number"
                                   class="form-control"
                                   min="1"
                                   max="99"
                                   t-model.number="state.copies"/>
                        </div>

                        <hr class="my-3"/>
                        <div class="text-muted" style="font-size:12px; line-height:1.5;">
                            <i class="fa fa-info-circle me-1"/>
                            Additional printer options (paper size, margins, colour) are available in your system's print dialog after clicking <strong>Print</strong>.
                        </div>
                    </div>

                    <!-- ── Footer buttons ────────────────────────────────── -->
                    <div class="cpd-settings-footer border-top p-3 d-flex flex-column gap-2" style="background:#fafafa; flex-shrink:0;">

                        <!--
                            PRINT button → opens PDF in a new tab and triggers
                            the browser's native Ctrl+P / system print dialog.
                        -->
                        <button class="btn btn-primary w-100" t-on-click="onPrint">
                            <i class="fa fa-print me-2"/>
                            Print
                        </button>

                        <!--
                            SAVE AS PDF button → downloads the PDF file to disk
                            (same as Odoo's original Print button behaviour).
                        -->
                        <button class="btn btn-outline-primary w-100" t-on-click="onDownloadPDF">
                            <i class="fa fa-download me-2"/>
                            Save as PDF
                        </button>

                        <!-- Cancel -->
                        <button class="btn btn-outline-secondary w-100" t-on-click="onClose">
                            Cancel
                        </button>
                    </div>

                </div>
                <!-- end right panel -->

            </div>
            <!-- end body -->

        </Dialog>
    </t>

</templates>

