<?xml version="1.0" encoding="utf-8" ?>
<odoo>

    <!-- ============================================================
         stock.valuation.layer  –  main list (matches Image 2 style)
    ============================================================ -->
    <record id="stock_valuation_layer_custom_list" model="ir.ui.view">
        <field name="name">stock.valuation.layer.custom.list</field>
        <field name="model">stock.valuation.layer</field>
        <field name="arch" type="xml">
            <list create="false" edit="false" delete="false"
                  default_order="create_date desc">
                <header>
                    <!-- "Valuation at Date" button in the control panel -->
                    <button
                        string="Valuation at Date"
                        type="action"
                        name="%(stock_account_valuation_report.history_valuation_action)d"
                        class="btn-primary"
                    />
                </header>
                <field name="create_date"   string="Date" />
                <field name="reference"     string="Reference" />
                <field name="product_id"    string="Product" />
                <field name="quantity"      string="Quantity"   optional="show" />
                <field name="uom_id"        string="Unit"       groups="uom.group_uom"
                                            column_invisible="1"/>
                <field name="currency_id"   column_invisible="1" />
                <field name="value"         string="Total Value"
                                            widget="monetary"
                                            options="{'currency_field': 'currency_id'}"
                                            optional="show" />
                <!-- Optional / hidden columns  (matches the dropdown in Image 2) -->
                <field name="account_move_id"   string="Journal Entry"      optional="hide" />
                <field name="lot_id"            string="Lot/Serial Number"  optional="hide" />
                <field name="remaining_qty"     string="Remaining Qty"      optional="hide" />
                <field name="unit_cost"         string="Unit Value"
                                                widget="monetary"
                                                options="{'currency_field': 'currency_id'}"
                                                optional="hide" />
                <field name="description"       string="Description"        optional="hide" />
                <field name="remaining_value"   string="Remaining Value"
                                                widget="monetary"
                                                options="{'currency_field': 'currency_id'}"
                                                optional="hide" />
            </list>
        </field>
    </record>

    <!-- Window action that opens the SVL list above -->
    <record id="stock_valuation_layer_action" model="ir.actions.act_window">
        <field name="name">Stock Valuation</field>
        <field name="res_model">stock.valuation.layer</field>
        <field name="view_mode">list,form</field>
        <field name="view_id" ref="stock_valuation_layer_custom_list" />
        <field name="context">{'create': False}</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                No valuation entries found.
            </p>
        </field>
    </record>

    <!-- ============================================================
         product.product  –  Dual Inventory Valuation list
         (kept for the "open_at_date" wizard flow if still needed)
    ============================================================ -->
    <record id="view_stock_product_tree2" model="ir.ui.view">
        <field name="name">product.stock.tree.2</field>
        <field name="model">product.product</field>
        <field name="arch" type="xml">
            <list>
                <field name="display_name" />
                <field name="qty_at_date" />
                <field name="uom_id" groups="uom.group_uom" />
                <field name="currency_id"      column_invisible="1" />
                <field name="cost_currency_id" column_invisible="1" />
                <field name="valuation"        column_invisible="1" />
                <field
                    name="stock_value"
                    sum="Stock Valuation"
                    widget="monetary"
                    options="{'currency_field': 'cost_currency_id'}"
                />
                <button
                    name="action_view_valuation_layers"
                    type="object"
                    icon="fa-info-circle"
                    title="View Valuation Layers"
                    invisible="valuation != 'real_time'"
                />
                <field
                    name="account_qty_at_date"
                    sum="Accounting Qty"
                    invisible="valuation != 'real_time'"
                />
                <field
                    name="account_value"
                    sum="Accounting Valuation"
                    widget="monetary"
                    invisible="valuation != 'real_time'"
                />
                <button
                    name="action_view_amls"
                    type="object"
                    icon="fa-info-circle"
                    title="View Journal Items"
                    invisible="valuation != 'real_time'"
                />
                <field name="qty_discrepancy"       sum="Qty Discrepancy" />
                <field name="valuation_discrepancy" sum="Valuation Discrepancy" />
            </list>
        </field>
    </record>

    <!-- Action kept for the wizard's "open_at_date" fallback -->
    <record id="product_valuation_action" model="ir.actions.act_window">
        <field name="name">Dual Inventory Valuation</field>
        <field name="res_model">product.product</field>
        <field name="view_mode">list,form</field>
        <field name="view_id" ref="view_stock_product_tree2" />
        <field name="domain">[('type', '=', 'consu')]</field>
        <field name="context">{'company_owned': True, 'create': False, 'edit': False}</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Create a product to see its name and valuation.
            </p>
        </field>
    </record>

    <!-- Search view: extra filters for product.product -->
    <record id="product_search_form_view" model="ir.ui.view">
        <field name="name">product.product.search</field>
        <field name="model">product.product</field>
        <field name="inherit_id" ref="product.product_search_form_view" />
        <field name="arch" type="xml">
            <field name="name" position="after">
                <field name="valuation_discrepancy" />
            </field>
            <filter name="inactive" position="after">
                <separator />
                <filter
                    string="Real time"
                    name="real_valuation"
                    domain="[('valuation', '=', 'real_time')]"
                />
                <separator />
                <filter
                    string="Manual"
                    name="manual_valuation"
                    domain="[('valuation', '=', 'manual_periodic')]"
                />
                <separator />
                <filter
                    string="Qty Discrepancy"
                    name="qty_discrepancy_not_null"
                    domain="[('qty_discrepancy', '!=', 0.0), ('valuation', '=', 'real_time')]"
                />
                <separator />
                <filter
                    string="Valuation Discrepancy"
                    name="valuation_discrepancy_not_null"
                    domain="[('valuation_discrepancy', '!=', 0.0), ('valuation', '=', 'real_time')]"
                />
                <separator />
                <filter
                    string="Valuation Or Qty Discrepancy"
                    name="valuation_or_qty_discrepancy_not_null"
                    domain="[('valuation', '=', 'real_time'), '|', ('qty_discrepancy', '!=', 0.0), ('valuation_discrepancy', '!=', 0.0)]"
                />
            </filter>
        </field>
    </record>

</odoo>
