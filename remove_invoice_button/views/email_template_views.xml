<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <!-- Extend mail.template form view -->
        <record id="email_template_form_view_extended" model="ir.ui.view">
            <field name="name">mail.template.form.remove.invoice.button</field>
            <field name="model">mail.template</field>
            <field name="inherit_id" ref="mail.email_template_form" />
            <field name="arch" type="xml">
                <!-- Add field after the email_to field -->
                <xpath expr="//field[@name='email_to']" position="after">
                    <field name="remove_invoice_button" />
                </xpath>
            </field>
        </record>

    </data>
</odoo>