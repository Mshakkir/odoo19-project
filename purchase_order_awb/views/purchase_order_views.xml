<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <!-- Inherit Purchase Order Form -->
        <record id="purchase_order_form_awb" model="ir.ui.view">
            <field name="name">purchase.order.form.awb</field>
            <field name="model">purchase.order</field>
            <field name="inherit_id" ref="purchase.purchase_order_form"/>
            <field name="arch" type="xml">

                <!-- Add Delivery Address field right after partner_id -->
                <field name="partner_id" position="after">
                    <field
                        name="delivery_address_id"
                        string="Delivery Address"
                        domain="[('parent_id', '=', current_company_id), ('type', '=', 'delivery')]"
                        context="{'show_address': 1, 'default_type': 'delivery', 'default_parent_id': current_company_id}"
                        options="{'no_create': False}"
                    />
                </field>

                <!-- Add AWB, Incoterm, Payment Terms after date_planned div -->
                <xpath expr="//div[@name='date_planned_div']" position="after">
                    <label for="awb_number" string="Shipping Ref#"/>
                    <field name="awb_number" nolabel="1" placeholder="Enter AWB Number (e.g., 1234567890)" readonly="state in ('cancel', 'purchase')"/>
                    <label for="incoterm_id" string="Incoterm"/>
                    <field name="incoterm_id" nolabel="1"/>
                    <label for="payment_term_id" string="Payment Terms"/>
                    <field name="payment_term_id" nolabel="1" readonly="invoice_status == 'invoiced' or locked" options="{'no_create': True}"/>
                </xpath>

                <!-- Editable currency rate under currency_id field -->
                <xpath expr="//field[@name='currency_id'][@groups='base.group_multi_currency']" position="after">
                    <label for="manual_currency_rate" string=" "
                        invisible="currency_rate_prefix == ''"/>
                    <div class="o_row" invisible="currency_rate_prefix == ''">
                        <span>
                            <field name="currency_rate_prefix" nolabel="1" readonly="1" widget="char" class="oe_inline"/>
                        </span>
                        <field name="manual_currency_rate"
                            nolabel="1"
                            widget="float"
                            digits="[12,6]"
                            readonly="state in ('cancel', 'purchase')"
                            class="oe_inline"
                            style="max-width: 100px;"
                        />
                        <span>
                            <field name="currency_rate_suffix" nolabel="1" readonly="1" widget="char" class="oe_inline"/>
                        </span>
                    </div>
                </xpath>

                <!-- =========================================================
                     Replace oe_subtotal_footer group entirely.
                     - Keep tax_totals for USD Untaxed/Total display
                     - Add our manual-rate SAR total below
                     - The built-in (1,875 SR) line inside tax_totals widget
                       is hidden via the company_currency_id trick:
                       passing False makes the widget skip currency conversion row
                     ========================================================= -->
                <xpath expr="//group[@class='oe_subtotal_footer']" position="replace">
                    <group class="oe_subtotal_footer">
                        <field name="tax_totals"
                            widget="account-tax-totals-field"
                            nolabel="1"
                            readonly="1"
                            context="{'company_currency_id': False}"
                        />
                        <field name="company_currency_id" invisible="1"/>
                        <div class="o_td_label" invisible="currency_id == company_currency_id"/>
                        <field
                            name="amount_total_company_currency"
                            nolabel="1"
                            widget="monetary"
                            options="{'currency_field': 'company_currency_id'}"
                            readonly="1"
                            class="text-muted fst-italic"
                            invisible="currency_id == company_currency_id"
                        />
                    </group>
                </xpath>

            </field>
        </record>

        <!-- List view — add AWB column -->
        <record id="purchase_order_tree_awb" model="ir.ui.view">
            <field name="name">purchase.order.tree.awb</field>
            <field name="model">purchase.order</field>
            <field name="inherit_id" ref="purchase.purchase_order_tree"/>
            <field name="arch" type="xml">
                <field name="amount_total" position="after">
                    <field name="awb_number" optional="show"/>
                </field>
            </field>
        </record>

    </data>
</odoo>







