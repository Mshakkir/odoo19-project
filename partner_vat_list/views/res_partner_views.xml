<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!--
        Inherit the standard res.partner form view (base.view_partner_form)
        to add:
          SALES section   → Sales VAT List + Sales Currency + Currency Rate
          PURCHASE section → Purchase VAT List
    -->
    <record id="view_partner_form_vat_list" model="ir.ui.view">
        <field name="name">res.partner.form.vat.list</field>
        <field name="model">res.partner</field>
        <field name="inherit_id" ref="base.view_partner_form"/>
        <field name="arch" type="xml">

            <!-- ══════════════════════════════════════════════════════════
                 SALES section
            ══════════════════════════════════════════════════════════ -->
            <xpath expr="//page[@name='sales_purchases']//group[@name='sale']" position="inside">

                <!-- Sales VAT List -->
                <field
                    name="sale_tax_ids"
                    widget="many2many_tags"
                    string="Sales VAT List"
                    options="{'no_create_edit': True}"
                    placeholder="Select sales VAT taxes..."
                    domain="[('type_tax_use', 'in', ('sale', 'all'))]"
                />

                <!-- Hidden helper fields needed for prefix/suffix compute + visibility -->
                <field name="company_currency_id" invisible="1"/>
                <field name="currency_rate_prefix"  invisible="1"/>
                <field name="currency_rate_suffix"  invisible="1"/>

                <!-- Sales Currency selector -->
                <label for="sale_currency_id" string="Sales Currency"/>
                <div>
                    <field
                        name="sale_currency_id"
                        options="{'no_create': True}"
                        style="width:150px;"
                        class="oe_inline"
                        placeholder="Default sales currency..."
                    />
                </div>

                <!-- Currency Rate row — visible only when currency differs from company currency -->
                <label
                    for="manual_currency_rate"
                    string=" "
                    invisible="not sale_currency_id or sale_currency_id == company_currency_id"
                />
                <div invisible="not sale_currency_id or sale_currency_id == company_currency_id">
                    <field name="currency_rate_prefix" readonly="1" class="oe_inline"/>
                    <field
                        name="manual_currency_rate"
                        widget="float"
                        digits="[12,6]"
                        class="oe_inline"
                        style="width:110px;"
                    />
                    <field name="currency_rate_suffix" readonly="1" class="oe_inline"/>
                </div>

            </xpath>

            <!-- ══════════════════════════════════════════════════════════
                 PURCHASE section
            ══════════════════════════════════════════════════════════ -->
            <xpath expr="//page[@name='sales_purchases']//group[@name='purchase']" position="inside">

                <!-- Purchase VAT List -->
                <field
                    name="purchase_tax_ids"
                    widget="many2many_tags"
                    string="Purchase VAT List"
                    options="{'no_create_edit': True}"
                    placeholder="Select purchase VAT taxes..."
                    domain="[('type_tax_use', 'in', ('purchase', 'all'))]"
                />

            </xpath>

        </field>
    </record>
</odoo>