<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!--
        Odoo 19 CE: Standalone res.config.settings view using the new
        <app>/<block>/<setting> DSL. Odoo automatically merges all
        res.config.settings views — no xpath or inherit_id needed.
    -->
    <record id="res_config_settings_view_purchase_bill_cost" model="ir.ui.view">
        <field name="name">res.config.settings.view.purchase.bill.cost</field>
        <field name="model">res.config.settings</field>
        <field name="priority">100</field>
        <field name="arch" type="xml">
            <form string="Settings">
                <app string="Accounting" name="account">
                    <block title="Vendor Bill - Product Cost Update">
                        <setting string="Update Product Cost on Bill Confirmation"
                                 help="When enabled, posting a vendor bill will automatically update the product's cost price (Standard Price) with the unit price from the bill line.">
                            <field name="auto_update_cost_on_bill" widget="boolean_toggle"/>
                        </setting>
                    </block>
                </app>
            </form>
        </field>
    </record>
</odoo>