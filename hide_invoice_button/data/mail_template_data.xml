<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="0">

        <record id="account.email_template_edi_invoice" model="mail.template">

            <!-- Fix sender name: always show "SSAOC" regardless of which user sends -->
            <field name="email_from">SSAOC &lt;{{ object.company_id.email or user.email }}&gt;</field>

            <!-- Fix: Auto-fill "To" field with customer email -->
            <field name="partner_to">{{ object.partner_id.id }}</field>

        </record>

    </data>
</odoo>









