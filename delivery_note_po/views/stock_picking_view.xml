<odoo>
    <record id="view_picking_form_customer_ref" model="ir.ui.view">
        <field name="name">stock.picking.form.customer.ref</field>
        <field name="model">stock.picking</field>
        <field name="inherit_id" ref="stock.view_picking_form"/>
        <field name="arch" type="xml">

            <!-- Replace origin field to add clickable sale order link beside it -->
            <xpath expr="//field[@name='origin']" position="after">
                <!-- Clickable link to the Sales Order (replaces plain text origin) -->
                <field name="sale_order_link_id"
                       string="Sales Order"
                       readonly="1"
                       invisible="not sale_order_link_id"
                       options="{'no_open': False}"/>
                <!-- Customer Reference from the Sale Order -->
                <field name="sale_customer_reference"
                       string="Customer Reference"
                       readonly="1"
                       invisible="not sale_customer_reference"/>
            </xpath>

        </field>
    </record>
</odoo>