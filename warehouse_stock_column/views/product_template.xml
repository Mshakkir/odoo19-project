<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- LIST VIEW: Created Date column (dd/mm/yy) before Product Name -->
    <record id="product_template_list_created_date" model="ir.ui.view">
        <field name="name">product.template.list.created_date</field>
        <field name="model">product.template</field>
        <field name="inherit_id" ref="product.product_template_tree_view"/>
        <field name="arch" type="xml">

            <field name="name" position="before">
                <field
                    name="x_created_date_display"
                    string="Created Date"
                    readonly="1"
                    optional="show"
                    style="width: 90px; min-width: 90px;"
                />
            </field>

        </field>
    </record>

    <!-- LIST VIEW: Warehouse stock + total price columns -->
    <record id="product_template_list_warehouse_columns" model="ir.ui.view">
        <field name="name">product.template.list.warehouse.columns</field>
        <field name="model">product.template</field>
        <field name="inherit_id" ref="product.product_template_tree_view"/>
        <field name="arch" type="xml">

            <!-- Set width on existing columns -->
            <field name="name" position="attributes">
                <attribute name="style">width: 180px; min-width: 150px;</attribute>
            </field>
            <field name="default_code" position="attributes">
                <attribute name="style">width: 120px; min-width: 100px;</attribute>
            </field>
            <field name="list_price" position="attributes">
                <attribute name="style">width: 100px; min-width: 90px;</attribute>
            </field>
            <field name="standard_price" position="attributes">
                <attribute name="style">width: 100px; min-width: 90px;</attribute>
            </field>
            <field name="qty_available" position="attributes">
                <attribute name="style">width: 90px; min-width: 80px;</attribute>
            </field>

            <!-- Warehouse stock columns after Internal Reference — with sum -->
            <field name="default_code" position="after">
                <field name="qty_fyh_stock" string="FYH/Stock" optional="show" sum="FYH/Stock" style="width: 90px; min-width: 80px;"/>
                <field name="qty_bld_stock" string="BLD/Stock" optional="show" sum="BLD/Stock" style="width: 90px; min-width: 80px;"/>
                <field name="qty_dmm_stock" string="DMM-1/Stock" optional="show" sum="DMM-1/Stock" style="width: 100px; min-width: 90px;"/>
            </field>

            <!-- Total price columns after On Hand — with sum -->
            <field name="qty_available" position="after">
                <field name="total_sales_price" string="Total Sales Price" optional="show" sum="Total Sales Price" style="width: 120px; min-width: 110px;"/>
                <field name="total_cost_price" string="Total Cost Price" optional="show" sum="Total Cost Price" style="width: 120px; min-width: 110px;"/>
            </field>

        </field>
    </record>

</odoo>







