<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <record id="view_account_payment_list_custom" model="ir.ui.view">
            <field name="name">account.payment.list.custom</field>
            <field name="model">account.payment</field>
            <field name="inherit_id" ref="account.view_account_payment_tree"/>
            <field name="arch" type="xml">

                <!-- 1. Replace the Date field with date_display (computed Char: dd/mm/yy).
                        position="replace" swaps it in-place so column order is unchanged. -->
                <xpath expr="//field[@name='date']" position="replace">
                    <field name="date_display"
                           string="Date"
                           readonly="1"/>
                </xpath>

                <!-- 2. Replace amount_company_currency_signed (system-rate based)
                        with amount_manual_company_currency (manual-rate based).
                        Keeps the same "Amount" label and sum="Total" footer. -->
                <xpath expr="//field[@name='amount_company_currency_signed']" position="replace">
                    <field name="amount_manual_company_currency"
                           widget="monetary"
                           string="Amount"
                           sum="Total"
                           readonly="1"/>
                </xpath>

            </field>
        </record>
    </data>
</odoo>
