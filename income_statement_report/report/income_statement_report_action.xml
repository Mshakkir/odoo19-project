<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="action_income_statement_report" model="ir.actions.report">
        <field name="name">Income Statement</field>
        <field name="model">income.statement.wizard</field>
        <field name="report_type">qweb-pdf</field>
        <field name="report_name">income_statement_report.report_income_statement_template</field>
        <field name="report_file">income_statement_report.report_income_statement_template</field>
        <field name="print_report_name">'Income_Statement_%s_%s' % (object.date_from, object.date_to)</field>
        <field name="binding_model_id" ref="base.model_res_company"/>
        <field name="paperformat_id" ref="base.paperformat_euro"/>
    </record>

</odoo>