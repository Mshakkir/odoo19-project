<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- Inherit the Partner Ledger Wizard View -->
    <record id="account_report_partner_ledger_custom_view" model="ir.ui.view">
        <field name="name">Custom Partner Ledger Wizard</field>
        <field name="model">account.report.partner.ledger</field>
        <field name="inherit_id" ref="accounting_pdf_reports.account_report_partner_ledger_view"/>
        <field name="arch" type="xml">

            <!-- Rename partner_ids label -->
            <xpath expr="//field[@name='partner_ids']" position="attributes">
                <attribute name="string">Customers &amp; Vendors</attribute>
            </xpath>

            <!-- Add manual exchange rate section just before the footer -->
            <xpath expr="//footer" position="before">
                <div style="margin: 0 0 8px 0;">
                    <group col="2">
                        <field name="use_manual_rate" widget="boolean_toggle"
                               string="Use Manual Exchange Rate"/>
                        <field name="company_currency_id" invisible="1"/>
                    </group>

                    <!-- Exchange Rate block — visible only when use_manual_rate is checked -->
                    <!-- Odoo 17+/19: use inline invisible expression, NOT attrs= -->
                    <group col="2" invisible="not use_manual_rate">
                        <group string="Exchange Rate" col="1"
                               style="border:1px solid #d0d0d0; border-radius:4px; padding:8px;">

                            <!-- Currency selection -->
                            <field name="manual_rate_currency_id"
                                   string="Foreign Currency"
                                   placeholder="e.g. USD"
                                   options="{'no_create': True}"/>

                            <!-- Rate amount -->
                            <field name="manual_currency_exchange_rate"
                                   string="Rate (1 foreign = ? company)"
                                   digits="[12,6]"/>

                            <!-- Live preview label -->
                            <field name="rate_display"
                                   string="Preview"
                                   readonly="1"
                                   style="color:#5c5c5c; font-style:italic;"/>

                            <div style="font-size:11px; color:#888; margin-top:4px;">
                                Enter how many
                                <strong>
                                    <field name="company_currency_id" readonly="1"
                                           options="{'no_open':True}" nolabel="1"
                                           style="display:inline;"/>
                                </strong>
                                equal <strong>1</strong> unit of the foreign currency.
                            </div>
                        </group>
                    </group>
                </div>
            </xpath>

            <!-- Buttons in footer -->
            <xpath expr="//footer" position="inside">
                <button string="Show Details"
                        name="action_show_details"
                        type="object"
                        class="btn-primary"
                        data-hotkey="d"/>
            </xpath>

        </field>
    </record>

</odoo>









