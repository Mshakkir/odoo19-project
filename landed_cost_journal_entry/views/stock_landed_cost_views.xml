<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- ===================================================================
         Inherit the Landed Cost form view to add Journal Entry fields
         Odoo 19 CE - correct view ref: stock_landed_costs.view_stock_landed_cost_form
         =================================================================== -->
    <record id="view_stock_landed_cost_form_inherit_journal" model="ir.ui.view">
        <field name="name">stock.landed.cost.form.inherit.journal.entry</field>
        <field name="model">stock.landed.cost</field>
        <field name="inherit_id" ref="stock_landed_costs.view_stock_landed_cost_form"/>
        <field name="arch" type="xml">

            <!-- 1. ADD SMART BUTTON before the sheet (creates button box) -->
            <xpath expr="//sheet" position="before">
                <div class="oe_button_box" name="button_box">
                    <button name="action_open_all_journal_entries"
                            type="object"
                            class="oe_stat_button"
                            icon="fa-book"
                            invisible="account_move_count == 0">
                        <field name="account_move_count"
                               widget="statinfo"
                               string="Journal Entries"/>
                    </button>
                </div>
            </xpath>

            <!-- 2. Replace the existing hidden account_move_id field
                    to make it always visible with a proper label -->
            <xpath expr="//field[@name='account_move_id']" position="replace">
                <field name="account_move_id"
                       string="Journal Entry"
                       readonly="1"
                       invisible="not account_move_id"/>
            </xpath>

            <!-- 3. ADD Extra Journal Entries + Auto-Compute toggle after vendor_bill_id -->
            <xpath expr="//field[@name='vendor_bill_id']" position="after">
                <field name="auto_compute_from_moves"
                       string="Auto-Compute Cost from Journal Entries"
                       widget="boolean_toggle"/>
                <field name="extra_account_move_ids"
                       string="Extra Journal Entries"
                       widget="many2many_tags"
                       domain="[('move_type', '=', 'entry'), ('state', '=', 'posted')]"
                       options="{'no_create': True}"
                       invisible="not auto_compute_from_moves"/>
            </xpath>

        </field>
    </record>

</odoo>
