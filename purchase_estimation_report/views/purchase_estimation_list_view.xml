<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- List View for Estimation Lines -->
    <record id="view_purchase_estimation_line_list" model="ir.ui.view">
        <field name="name">purchase.estimation.line.list</field>
        <field name="model">purchase.estimation.line</field>
        <field name="arch" type="xml">
            <list string="Purchase Estimation Balance Register"
                  create="false" edit="false" delete="false"
                  decoration-info="net_amount == 0">
                <field name="vno" string="Vno"/>
                <field name="date" string="Date"/>
                <field name="customer" string="Vendor"/>
                <field name="address" string="Address"/>
                <field name="cell_no" string="Cell No"/>
                <field name="narration" string="Narration"/>
                <field name="net_amount" string="Net Amount"
                       widget="monetary" options="{'currency_field': 'currency_id'}"/>
                <field name="confirm_date" string="Confirm Date"/>
                <field name="required_date" string="Required Date"/>
            </list>
        </field>
    </record>

</odoo>
