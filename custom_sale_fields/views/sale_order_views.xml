<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <!-- Inherit Sale Order Form View -->
        <record id="view_order_form_custom_fields" model="ir.ui.view">
            <field name="name">sale.order.form.custom.fields</field>
            <field name="model">sale.order</field>
            <field name="inherit_id" ref="sale.view_order_form"/>
            <field name="arch" type="xml">

                <!-- Add client_order_ref, AWB below Payment Terms -->
                <xpath expr="//field[@name='payment_term_id']" position="after">
                    <field name="client_order_ref" placeholder="Enter Customer Reference / PO Number..."/>
                    <field name="awb_number" placeholder="Enter AWB number..."/>
                </xpath>

                <!-- HIDE PRICELIST label (pricelist feature ON) -->
                <xpath expr="//label[@for='pricelist_id'][@groups='product.group_product_pricelist']" position="replace"/>

                <!-- HIDE PRICELIST field + Update Prices button div -->
                <xpath expr="//div[@groups='product.group_product_pricelist'][@class='o_row']" position="replace"/>

                <!-- HIDE PRICELIST invisible fallback (pricelist feature OFF) -->
                <xpath expr="//field[@name='pricelist_id'][@groups='!product.group_product_pricelist']" position="replace"/>

                <!-- After hiding pricelist, inject Currency + manual rate in same group/position -->
                <xpath expr="//field[@name='payment_term_id']" position="after">
                    <label for="currency_id" string="Currency"/>
                    <field name="currency_id"
                           options="{'no_create': True}"
                           readonly="state in ['cancel', 'sale']"/>
                    <!-- Rate row: only visible when order currency differs from company currency -->
                    <label for="manual_currency_rate" string=" "
                           invisible="currency_rate_prefix == ''"/>
                    <div class="o_row" invisible="currency_rate_prefix == ''">
                        <span>
                            <field name="currency_rate_prefix" nolabel="1" readonly="1"
                                   widget="char" class="oe_inline"/>
                        </span>
                        <field name="manual_currency_rate"
                               nolabel="1"
                               widget="float"
                               digits="[12,6]"
                               readonly="state in ['cancel', 'sale']"
                               class="oe_inline"
                               style="max-width: 100px;"/>
                        <span>
                            <field name="currency_rate_suffix" nolabel="1" readonly="1"
                                   widget="char" class="oe_inline"/>
                        </span>
                    </div>
                </xpath>

                <!-- Add converted total in company currency below tax_totals -->
                <xpath expr="//field[@name='tax_totals']" position="after">
                    <field name="company_currency_id" invisible="1"/>
                    <div class="o_td_label"
                         invisible="currency_id == company_currency_id"/>
                    <field name="amount_total_company_currency"
                           nolabel="1"
                           widget="monetary"
                           options="{'currency_field': 'company_currency_id'}"
                           readonly="1"
                           class="text-muted fst-italic"
                           invisible="currency_id == company_currency_id"/>
                </xpath>

            </field>
        </record>

        <!-- Add fields to tree view for quick reference -->
        <record id="view_order_tree_custom_fields" model="ir.ui.view">
            <field name="name">sale.order.tree.custom.fields</field>
            <field name="model">sale.order</field>
            <field name="inherit_id" ref="sale.view_order_tree"/>
            <field name="arch" type="xml">
                <xpath expr="//field[@name='amount_total']" position="after">
                    <field name="client_order_ref" optional="hide"/>
                    <field name="awb_number" optional="hide"/>
                </xpath>
            </field>
        </record>

        <!-- Add search filters -->
        <record id="view_sales_order_filter_custom" model="ir.ui.view">
            <field name="name">sale.order.search.custom.fields</field>
            <field name="model">sale.order</field>
            <field name="inherit_id" ref="sale.view_sales_order_filter"/>
            <field name="arch" type="xml">
                <xpath expr="//search" position="inside">
                    <field name="client_order_ref" string="Customer Reference"
                           filter_domain="[('client_order_ref', 'ilike', self)]"/>
                    <field name="awb_number" string="AWB Number"
                           filter_domain="[('awb_number', 'ilike', self)]"/>
                </xpath>
            </field>
        </record>
    </data>
</odoo>










