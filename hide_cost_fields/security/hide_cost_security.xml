<odoo>
    <data>

        <!-- Group: users who CANNOT see Cost price fields -->
        <record id="group_hide_cost" model="res.groups">
            <field name="name">Cannot See Cost Price</field>
        </record>

        <!-- Group: users who CANNOT see Sales price fields -->
        <record id="group_hide_sales_price" model="res.groups">
            <field name="name">Cannot See Sales Price</field>
        </record>

    </data>
</odoo>




