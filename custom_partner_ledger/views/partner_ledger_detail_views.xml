<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="view_partner_ledger_detail_tree" model="ir.ui.view">
        <field name="name">partner.ledger.detail.tree</field>
        <field name="model">partner.ledger.detail</field>
        <field name="arch" type="xml">
            <list create="false" edit="false" delete="false">
                <field name="date"/>
                <field name="partner_id"/>
                <field name="move_id"/>
                <field name="journal_id"/>
                <field name="account_id"/>
                <field name="name"/>
                <field name="ref"/>
                <field name="debit"/>
                <field name="credit"/>
                <field name="balance"/>
                <field name="is_opening_balance" column_invisible="1"/>
                <field name="company_currency_id" column_invisible="1"/>
            </list>
        </field>
    </record>

    <record id="view_partner_ledger_detail_search" model="ir.ui.view">
        <field name="name">partner.ledger.detail.search</field>
        <field name="model">partner.ledger.detail</field>
        <field name="arch" type="xml">
            <search>
                <field name="partner_id"/>
                <field name="account_id"/>
                <field name="journal_id"/>
            </search>
        </field>
    </record>

</odoo>
