<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="product_template_form_view_created_date" model="ir.ui.view">
        <field name="name">product.template.form.created_date</field>
        <field name="model">product.template</field>
        <field name="inherit_id" ref="product.product_template_only_form_view"/>
        <field name="arch" type="xml">

            <!--
                Place 'Created Date' right after the product name field
                at the top of the General Information tab.
                Adjust the xpath target below if you prefer a different location.
            -->
            <xpath expr="//field[@name='categ_id']" position="after">
                <field
                    name="x_created_date"
                    string="Created Date"
                    readonly="1"
                    widget="date"
                    options="{'format': 'dd/MM/yy'}"
                />
            </xpath>

        </field>
    </record>
</odoo>
