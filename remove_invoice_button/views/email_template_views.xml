<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <!-- Extend mail.template form view -->
        <record id="email_template_form_view_extended" model="ir.ui.view">
            <field name="name">mail.template.form.remove.invoice.button</field>
            <field name="model">mail.template</field>
            <field name="inherit_id" ref="mail.email_template_form" />
            <field name="arch" type="xml">
                <!-- Add the checkbox field to the Settings tab -->
                <xpath expr="//group[@string='Settings']" position="inside">
                    <field name="remove_invoice_button" />
                </xpath>
            </field>
        </record>

        <!-- Alternative: If the above xpath doesn't work, try this one -->
        <record id="email_template_form_view_extended_alt" model="ir.ui.view">
            <field name="name">mail.template.form.remove.invoice.button.alt</field>
            <field name="model">mail.template</field>
            <field name="inherit_id" ref="mail.email_template_form" />
            <field name="arch" type="xml">
                <!-- Add field to the end of the form if Settings group not found -->
                <xpath expr="//notebook" position="inside">
                    <page string="Invoice Settings">
                        <group>
                            <field name="remove_invoice_button" />
                        </group>
                    </page>
                </xpath>
            </field>
        </record>

    </data>
</odoo>