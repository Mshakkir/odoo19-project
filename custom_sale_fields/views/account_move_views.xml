<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <!-- Inherit Invoice Form View -->
        <record id="view_move_form_custom_fields" model="ir.ui.view">
            <field name="name">account.move.form.custom.fields</field>
            <field name="model">account.move</field>
            <field name="inherit_id" ref="account.view_move_form"/>
            <field name="arch" type="xml">

                <!-- Add custom fields + manual currency rate below journal_div -->
                <xpath expr="//div[@name='journal_div']" position="after">

                    <!-- Manual Currency Rate row (visible only when currency != company currency) -->
                    <field name="company_currency_id" invisible="1"/>
                    <field name="currency_rate_prefix" invisible="1"/>
                    <field name="currency_rate_suffix" invisible="1"/>
                    <label for="manual_currency_rate" string=" "
                           invisible="currency_id == company_currency_id or move_type not in ('out_invoice', 'out_refund', 'out_receipt')"/>
                    <div invisible="currency_id == company_currency_id or move_type not in ('out_invoice', 'out_refund', 'out_receipt')">
                        <field name="currency_rate_prefix" readonly="1" class="oe_inline"/>
                        <field name="manual_currency_rate"
                               widget="float"
                               digits="[12,6]"
                               class="oe_inline"
                               style="width:100px;"/>
                        <field name="currency_rate_suffix" readonly="1" class="oe_inline"/>
                    </div>

                    <!-- Other custom fields -->
                    <field name="client_order_ref" placeholder="Enter PO Number..."
                           invisible="move_type not in ('out_invoice', 'out_refund', 'out_receipt')"/>
                    <field name="awb_number" placeholder="Enter AWB number..."
                           invisible="move_type not in ('out_invoice', 'out_refund', 'out_receipt')"/>
                    <field name="delivery_note_number" placeholder="Enter delivery note number..."
                           invisible="move_type not in ('out_invoice', 'out_refund', 'out_receipt')"/>
                    <field name="invoice_incoterm_id" placeholder="Select Incoterm..."
                           invisible="move_type not in ('out_invoice', 'out_refund', 'out_receipt')"/>
                    <field name="payment_reference" placeholder="Enter payment reference.."
                           invisible="move_type not in ('out_invoice', 'out_refund', 'out_receipt')"/>
                </xpath>

            </field>
        </record>

        <!-- Add fields to invoice tree view -->
        <record id="view_invoice_tree_custom_fields" model="ir.ui.view">
            <field name="name">account.move.tree.custom.fields</field>
            <field name="model">account.move</field>
            <field name="inherit_id" ref="account.view_invoice_tree"/>
            <field name="arch" type="xml">
                <xpath expr="//field[@name='name']" position="after">
                    <field name="client_order_ref" optional="hide"/>
                    <field name="awb_number" optional="hide"/>
                    <field name="delivery_note_number" optional="hide"/>
                    <field name="invoice_incoterm_id" optional="hide"/>
                </xpath>
            </field>
        </record>

        <!-- Add search filters for invoices -->
        <record id="view_account_invoice_filter_custom" model="ir.ui.view">
            <field name="name">account.invoice.search.custom.fields</field>
            <field name="model">account.move</field>
            <field name="inherit_id" ref="account.view_account_invoice_filter"/>
            <field name="arch" type="xml">
                <xpath expr="//search" position="inside">
                    <field name="client_order_ref" string="PO Number"
                           filter_domain="[('ref', 'ilike', self)]"/>
                    <field name="awb_number" string="AWB Number"
                           filter_domain="[('awb_number', 'ilike', self)]"/>
                    <field name="delivery_note_number" string="Delivery Note"
                           filter_domain="[('delivery_note_number', 'ilike', self)]"/>
                    <field name="payment_reference" string="payment_reference"
                           filter_domain="[('payment_reference', 'ilike', self)]"/>
                    <field name="invoice_incoterm_id" string="Incoterm"/>
                </xpath>
            </field>
        </record>
    </data>
</odoo>










