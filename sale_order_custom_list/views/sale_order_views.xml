<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>

        <!-- Custom Sale Order List View - Inherit and modify -->
        <record id="view_order_tree_custom" model="ir.ui.view">
            <field name="name">sale.order.tree.custom</field>
            <field name="model">sale.order</field>
            <field name="inherit_id" ref="sale.view_order_tree"/>
            <field name="arch" type="xml">

                <xpath expr="//list" position="replace">
                    <list string="Sales Orders"
                          sample="1"
                          decoration-info="state == 'draft'"
                          decoration-muted="state == 'cancel'"
                          multi_edit="1">

                        <!-- Hidden technical fields -->
                        <field name="invoice_count" column_invisible="1"/>
                        <field name="date_order" column_invisible="1"/>
                        <field name="validity_date" column_invisible="1"/>
                        <field name="commitment_date" column_invisible="1"/>
                        <field name="company_currency_id" column_invisible="1"/>

                        <!-- 1. Order Date -->
                        <field name="date_order_formatted" string="Order Date" width="110px"/>

                        <!-- 2. Number -->
                        <field name="name" string="Number" readonly="1" width="130px"/>

                        <!-- 3. Customer -->
                        <field name="partner_id" string="Customer" width="150px"/>

                        <!-- 4. Warehouse -->
                        <field name="warehouse_id" string="Warehouse" optional="show" groups="stock.group_stock_multi_warehouses" width="120px"/>

                        <!-- 5. Customer Reference -->
                        <field name="client_order_ref" string="Customer Reference" optional="show" width="130px"/>

                        <!-- 6. Salesperson -->
                        <field name="user_id" string="Salesperson" optional="show" widget="many2one_avatar_user" width="130px"/>

                        <!-- 7. Total (Company Currency SAR) -->
                        <field name="amount_total_company_currency"
                               string="Total"
                               sum="Total"
                               widget="monetary"
                               options="{'currency_field': 'company_currency_id'}"
                               optional="show" width="120px"/>

                        <!-- 8. Source Document -->
                        <field name="origin" string="Source Document" optional="hide" width="130px"/>

                        <!-- 9. Status -->
                        <field name="state" string="Status" optional="show" widget="badge"
                               decoration-success="state in ('sale', 'done')"
                               decoration-info="state in ('draft', 'sent')"
                               width="90px"/>

                        <!-- 10. Invoice Status -->
                        <field name="invoice_status" string="Invoice Status" optional="show" widget="badge"
                               decoration-success="invoice_status == 'invoiced'"
                               decoration-warning="invoice_status == 'to invoice'"
                               decoration-info="invoice_status == 'no'"
                               width="110px"/>

                        <!-- 11. Tax Excluded (Company Currency SAR) -->
                        <field name="amount_untaxed_company_currency"
                               string="Tax Excluded"
                               sum="Total Untaxed"
                               widget="monetary"
                               options="{'currency_field': 'company_currency_id'}"
                               optional="hide" width="120px"/>

                        <!-- 12. Tax (Company Currency SAR) -->
                        <field name="amount_tax_company_currency"
                               string="Tax"
                               sum="Total Tax"
                               widget="monetary"
                               options="{'currency_field': 'company_currency_id'}"
                               optional="hide" width="100px"/>

                        <!-- 13. Delivery Date -->
                        <field name="commitment_date_formatted" string="Delivery Date" optional="hide" width="120px"/>

                        <!-- 14. Expiration -->
                        <field name="validity_date_formatted" string="Expiration" optional="hide" width="110px"/>

                        <!-- 15. Pricelist -->
                        <field name="pricelist_id" string="Pricelist" optional="hide" groups="product.group_sale_pricelist" width="120px"/>

                        <!-- 16. Payment Terms -->
                        <field name="payment_term_id" string="Payment Terms" optional="hide" width="140px"/>

                        <!-- 17. Fiscal Position -->
                        <field name="fiscal_position_id" string="Fiscal Position" optional="hide" width="130px"/>

                        <!-- 18. Currency -->
                        <field name="currency_id" string="Currency" optional="hide" width="80px"/>

                        <!-- 19. Company -->
                        <field name="company_id" string="Company" groups="base.group_multi_company" optional="hide" width="120px"/>

                        <!-- 20. Delivery Status -->
                        <field name="delivery_status" string="Delivery Status" optional="hide" widget="badge"
                               decoration-success="delivery_status == 'full'"
                               decoration-warning="delivery_status == 'partial'"
                               decoration-info="delivery_status == 'pending'"
                               width="110px"/>

                        <!-- 21. Sales Team -->
                        <field name="team_id" string="Sales Team" optional="hide" width="120px"/>

                        <!-- 22. Tags -->
                        <field name="tag_ids" string="Tags" optional="hide" widget="many2many_tags" width="150px"/>

                        <!-- 23. Incoterm -->
                        <field name="incoterm" string="Incoterm" optional="hide" width="100px"/>

                        <!-- 24. Shipping Policy -->
                        <field name="picking_policy" string="Shipping Policy" optional="hide" width="120px"/>

                        <!-- 25. Invoice Address -->
                        <field name="partner_invoice_id" string="Invoice Address" optional="hide" width="150px"/>

                        <!-- 26. Delivery Address -->
                        <field name="partner_shipping_id" string="Delivery Address" optional="hide" width="150px"/>

                        <!-- 27. Note -->
                        <field name="note" string="Terms and Conditions" optional="hide" width="180px"/>

                        <!-- 28. Activity -->
                        <field name="activity_ids" string="Next Activity" widget="list_activity" optional="hide" width="100px"/>

                        <!-- 29. Activity State -->
                        <field name="activity_state" string="Activity State" optional="hide" widget="badge"
                               decoration-success="activity_state == 'today'"
                               decoration-warning="activity_state == 'planned'"
                               decoration-danger="activity_state == 'overdue'"
                               width="110px"/>

                        <!-- 30. Activity User -->
                        <field name="activity_user_id" string="Responsible User" optional="hide" width="130px"/>

                        <!-- 31. Activity Type -->
                        <field name="activity_type_id" string="Next Activity Type" optional="hide" width="140px"/>

                        <!-- 32. Activity Date -->
                        <field name="activity_date_deadline" string="Next Activity Deadline" optional="hide" width="150px"/>

                        <!-- 33. Activity Summary -->
                        <field name="activity_summary" string="Activity Summary" optional="hide" width="150px"/>

                        <!-- 34. Message -->
                        <field name="message_needaction" string="Action Needed" optional="hide" width="110px"/>

                        <!-- 35. Campaign -->
                        <field name="campaign_id" string="Campaign" optional="hide" groups="base.group_no_one" width="120px"/>

                        <!-- 36. Medium -->
                        <field name="medium_id" string="Medium" optional="hide" groups="base.group_no_one" width="100px"/>

                        <!-- 37. Source -->
                        <field name="source_id" string="Source" optional="hide" groups="base.group_no_one" width="100px"/>

                        <!-- 38. Created By -->
                        <field name="create_uid" string="Created by" optional="hide" width="120px"/>

                        <!-- 39. Created On -->
                        <field name="create_date" string="Created on" optional="hide" width="130px"/>

                        <!-- 40. Last Updated By -->
                        <field name="write_uid" string="Last Updated by" optional="hide" width="130px"/>

                        <!-- 41. Last Updated On -->
                        <field name="write_date" string="Last Updated on" optional="hide" width="130px"/>

                    </list>
                </xpath>

            </field>
        </record>

    </data>
</odoo>










