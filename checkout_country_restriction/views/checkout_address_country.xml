<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <template id="restrict_checkout_country"
              inherit_id="website_sale.address_form_fields"
              name="Checkout: Short Address Code + Country Restriction">

        <!-- INSERT "Short Address Code" after the street2 input -->
        <xpath expr="//input[@name='street2']" position="after">
            <div class="mb-3 col-lg-12">
                <label class="col-form-label" for="short_address_code">Short Address Code</label>
                <input type="text"
                       name="short_address_code"
                       id="short_address_code"
                       class="form-control"
                       placeholder="e.g. ABCD1234"
                       t-att-value="partner.short_address_code if partner and partner.short_address_code else ''"/>
            </div>
        </xpath>

        <!--
            Replace ONLY the select element itself (not the parent div).
            This keeps the original label with its single star intact,
            and only swaps the dropdown options.
        -->
        <xpath expr="//select[@name='country_id']" position="replace">
            <select name="country_id"
                    id="country_id"
                    class="form-select"
                    required="required">
                <option value=""
                        disabled="disabled"
                        t-att-selected="not partner.country_id if partner else True">
                    Select Country
                </option>
                <option t-att-value="request.env.ref('base.sa').id"
                        t-att-selected="partner.country_id.id == request.env.ref('base.sa').id if partner and partner.country_id else False">
                    Saudi Arabia
                </option>
                <option t-att-value="request.env.ref('base.bh').id"
                        t-att-selected="partner.country_id.id == request.env.ref('base.bh').id if partner and partner.country_id else False">
                    Bahrain
                </option>
            </select>
        </xpath>

    </template>
</odoo>











