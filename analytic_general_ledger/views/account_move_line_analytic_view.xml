<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- Keep original view for account.move.line (used by other actions) -->
    <record id="view_general_ledger_analytic_line_tree" model="ir.ui.view">
        <field name="name">account.move.line.general.ledger.analytic.tree</field>
        <field name="model">account.move.line</field>
        <field name="arch" type="xml">
            <list string="General Ledger Details" create="false" edit="false">
                <field name="date"/>
                <field name="move_id" widget="many2one_clickable"/>
                <field name="journal_id"/>
                <field name="account_id"/>
                <field name="analytic_distribution" widget="analytic_distribution"/>
                <field name="partner_id"/>
                <field name="name"/>
                <field name="debit" sum="Total Debit"/>
                <field name="credit" sum="Total Credit"/>
                <field name="balance" sum="Balance"/>
            </list>
        </field>
    </record>

    <!-- New tree view for converted transient lines -->
    <record id="view_general_ledger_converted_line_tree" model="ir.ui.view">
        <field name="name">account.general.ledger.line.tree</field>
        <field name="model">account.general.ledger.line</field>
        <field name="arch" type="xml">
            <list string="General Ledger Details" create="false" edit="false" delete="false">
                <field name="date"/>
                <field name="move_name"/>
                <field name="journal_code" string="Journal"/>
                <field name="account_code" string="Account"/>
                <field name="partner_name" string="Partner"/>
                <field name="label" string="Label"/>
                <field name="debit" sum="Total Debit"/>
                <field name="credit" sum="Total Credit"/>
                <field name="balance" sum="Balance"/>
                <button name="action_open_move" string="View Entry"
                        type="object" icon="fa-external-link"/>
            </list>
        </field>
    </record>

    <!-- Action to open detailed view -->
    <record id="action_general_ledger_analytic_line" model="ir.actions.act_window">
        <field name="name">General Ledger Details (Analytic)</field>
        <field name="res_model">account.move.line</field>
        <field name="view_mode">list</field>
        <field name="view_id" ref="view_general_ledger_analytic_line_tree"/>
        <field name="domain">[]</field>
        <field name="context">{}</field>
    </record>

</odoo>












