<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!--
        Disable the Terms and Conditions block on the product page.
        Source: odoo/tutorials 19.0 - website_airproof/data/presets.xml
        The correct approach is deactivating the view, NOT using xpath.
        Template id: website_sale.product_custom_text
    -->
    <record id="website_sale.product_custom_text" model="ir.ui.view">
        <field name="active" eval="False"/>
    </record>

</odoo>
