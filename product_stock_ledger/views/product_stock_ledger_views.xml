<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- ══════════════════════════════════════════
         DELETE WIZARD VIEW
    ══════════════════════════════════════════ -->
    <record id="view_product_stock_ledger_delete_wizard" model="ir.ui.view">
        <field name="name">product.stock.ledger.delete.wizard.form</field>
        <field name="model">product.stock.ledger.delete.wizard</field>
        <field name="arch" type="xml">
            <form string="Delete Ledger Entries">
                <sheet>
                    <div class="o_form_view">

                        <!-- Warning banner -->
                        <div class="alert alert-warning mb-3" role="alert">
                            <strong>⚠ Warning:</strong>
                            You are about to permanently delete
                            <strong><field name="ledger_count" readonly="1"/> ledger entry(ies)</strong>
                            and their underlying stock moves.
                            This action <strong>cannot be undone</strong>.
                        </div>

                        <!-- Summary table -->
                        <group string="Entries to be deleted">
                            <field name="summary"
                                   widget="html"
                                   readonly="1"
                                   nolabel="1"
                                   colspan="2"/>
                        </group>

                        <!-- Hidden move_ids field -->
                        <field name="move_ids" widget="many2many_tags" invisible="1"/>

                    </div>
                </sheet>

                <footer>
                    <button name="action_confirm_delete"
                            string="Delete Permanently"
                            type="object"
                            class="btn-danger"
                            data-confirm="Are you sure? This will permanently delete the selected stock moves and cannot be undone."/>
                    <button name="action_cancel"
                            string="Cancel"
                            type="object"
                            class="btn-secondary"/>
                </footer>
            </form>
        </field>
    </record>


    <!-- ══════════════════════════════════════════
         LEDGER LIST VIEW  (with Delete action button)
    ══════════════════════════════════════════ -->
    <record id="view_product_stock_ledger_list" model="ir.ui.view">
        <field name="name">product.stock.ledger.list</field>
        <field name="model">product.stock.ledger</field>
        <field name="arch" type="xml">
            <list string="Product Stock Ledger"
                  create="false" edit="false" delete="false"
                  default_order="date desc">

                <!-- Toolbar action button (appears when rows are selected) -->
                <header>
                    <button name="action_open_delete_wizard"
                            string="Delete Selected Entries"
                            type="object"
                            class="btn-danger"
                            groups="stock.group_stock_manager"
                            confirm="This will permanently delete the selected stock moves. Continue?"/>
                </header>

                <field name="product_id"     string="Product"        optional="show" width="230px"/>
                <field name="warehouse_id"   string="Warehouse"      optional="show" width="100px"/>
                <field name="date_str"       string="Date"           optional="show" width="100px"/>
                <field name="voucher"        string="Voucher"        optional="show" width="200px"/>
                <field name="particulars"    string="Particulars"    optional="show" width="250px"/>
                <field name="move_type"      string="Type"           optional="show" width="60px"/>
                <field name="rec_qty"        string="Rec. Qty"       optional="show" width="90px"
                                             sum="Total Received"/>
                <field name="rec_rate"       string="Rec. Rate"      optional="show" width="90px"/>
                <field name="issue_qty"      string="Issue Qty"      optional="show" width="90px"
                                             sum="Total Issued"/>
                <field name="issue_rate"     string="Issue Rate"     optional="show" width="90px"/>
                <field name="balance"        string="Balance"        optional="show" width="90px"
                                             sum="Closing Balance"/>
                <field name="uom"            string="Unit"           optional="show" width="60px"/>
                <field name="invoice_status" string="Invoice Status" optional="show" width="120px"/>

            </list>
        </field>
    </record>


    <!-- ══════════════════════════════════════════
         WINDOW ACTION
    ══════════════════════════════════════════ -->
    <record id="action_product_stock_ledger_window" model="ir.actions.act_window">
        <field name="name">Product Stock Ledger</field>
        <field name="res_model">product.stock.ledger</field>
        <field name="view_mode">list</field>
        <field name="view_id" ref="view_product_stock_ledger_list"/>
        <field name="context">{}</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                No stock movements found.
            </p>
            <p>
                This ledger shows all confirmed stock moves with received quantity,
                issued quantity, and running balance per product and warehouse.
            </p>
        </field>
    </record>

</odoo>











