<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="view_account_payment_register_form_custom" model="ir.ui.view">
        <field name="name">account.payment.register.form.custom</field>
        <field name="model">account.payment.register</field>
        <field name="inherit_id" ref="account.view_account_payment_register_form"/>
        <field name="arch" type="xml">

            <!-- 1. Rename communication → Reference Number -->
            <xpath expr="//field[@name='communication']" position="attributes">
                <attribute name="string">Reference Number</attribute>
            </xpath>

            <!-- 2. Add Memo field after Reference Number -->
            <xpath expr="//field[@name='communication']" position="after">
                <field name="memo_new"
                       placeholder="Add additional notes here..."
                       invisible="not can_edit_wizard or (can_group_payments and not group_payment)"/>
            </xpath>

            <!-- 3. Exchange Rate row — placed AFTER the amount field.
                     <newline/> forces the group renderer onto a fresh row.
                     label (colspan=1) + div (colspan=3) fills the full row.
                     Visible only when payment currency ≠ company currency.  -->
            <xpath expr="//field[@name='amount']" position="after">
                <newline/>
                <label for="manual_currency_exchange_rate"
                       string="Exchange Rate"
                       invisible="currency_id == company_currency_id"/>
                <div invisible="currency_id == company_currency_id"
                     style="display:flex; align-items:center; gap:6px;">
                    <span style="color:#6c757d;">1</span>
                    <field name="payment_currency_name"
                           readonly="1"
                           nolabel="1"
                           style="font-weight:600; border:none;
                                  background:transparent; padding:0;
                                  min-width:32px; width:auto;"/>
                    <span style="color:#6c757d;">=</span>
                    <field name="manual_currency_exchange_rate"
                           nolabel="1"
                           digits="[12,6]"
                           style="width:120px;"/>
                    <field name="company_currency_name"
                           readonly="1"
                           nolabel="1"
                           style="font-weight:600; border:none;
                                  background:transparent; padding:0;
                                  min-width:32px; width:auto;"/>
                </div>
            </xpath>

        </field>
    </record>

</odoo>









