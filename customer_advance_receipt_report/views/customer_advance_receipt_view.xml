<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <!-- Customer Advance Receipt Report List View -->
        <record id="view_customer_advance_receipt_report_list" model="ir.ui.view">
            <field name="name">customer.advance.receipt.report.list</field>
            <field name="model">customer.advance.receipt.report</field>
            <field name="arch" type="xml">
                <list string="Customer Advance Receipt Report"
                      create="false"
                      edit="false"
                      delete="false">
                    <field name="date"/>
                    <field name="receipt_number"/>
                    <field name="journal_name"/>
                    <field name="payment_method"/>
                    <field name="customer_name"/>

                    <!-- Original amount in payment currency — no sum (mixed currencies) -->
                    <field name="currency_id" column_invisible="1"/>
                    <field name="amount"
                           widget="monetary"
                           options="{'currency_field': 'currency_id'}"/>

                    <!-- Company currency amount using manual exchange rate — sum is meaningful -->
                    <field name="company_currency_id" column_invisible="1"/>
                    <field name="amount_company_currency"
                           widget="monetary"
                           options="{'currency_field': 'company_currency_id'}"
                           string="Amount (Company Currency)"
                           sum="Total (Company Currency)"/>

                    <field name="payment_id" column_invisible="1"/>
                    <button name="action_open_payment"
                            type="object"
                            string="View Receipt"
                            class="btn-primary"
                            icon="fa-eye"/>
                </list>
            </field>
        </record>

        <!-- Customer Advance Receipt Report Action -->
        <record id="action_customer_advance_receipt_report" model="ir.actions.act_window">
            <field name="name">Customer Advance Receipt Report</field>
            <field name="res_model">customer.advance.receipt.report</field>
            <field name="view_mode">list</field>
            <field name="view_id" ref="view_customer_advance_receipt_report_list"/>
        </record>
    </data>
</odoo>













