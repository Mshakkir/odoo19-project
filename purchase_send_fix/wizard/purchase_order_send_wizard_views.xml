<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="purchase_order_send_wizard_form" model="ir.ui.view">
        <field name="name">purchase.order.send.wizard.form</field>
        <field name="model">purchase.order.send.wizard</field>
        <field name="arch" type="xml">
            <form string="Send">
                <field name="order_id" invisible="1"/>
                <field name="is_send_rfq" invisible="1"/>
                <field name="can_edit_body" invisible="1"/>
                <field name="model" invisible="1"/>
                <field name="res_ids" invisible="1"/>

                <!-- Mail composer -->
                <group>
                    <label for="mail_partner_ids" string="To"/>
                    <div>
                        <field
                            name="mail_partner_ids"
                            widget="many2many_tags_email"
                            placeholder="Add contacts to notify..."
                            options="{'no_quick_create': True}"
                            required="1"
                            context="{'show_email': True, 'form_view_ref': 'base.view_partner_simple_form'}"
                        />
                    </div>
                    <field name="subject" placeholder="Subject..." required="1"/>
                </group>

                <field name="body" widget="html" style="min-height:300px;"/>

                <footer>
                    <button
                        string="Send"
                        name="action_send"
                        type="object"
                        class="btn-primary"
                        data-hotkey="q"
                    />
                    <button
                        string="Discard"
                        name="action_discard"
                        type="object"
                        class="btn-secondary"
                        data-hotkey="x"
                    />
                </footer>
            </form>
        </field>
    </record>

</odoo>