<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <!-- Inherit the account move form to add new fields -->
        <record id="account_move_vendor_bill_custom_form" model="ir.ui.view">
            <field name="name">account.move.vendor.bill.custom.form</field>
            <field name="model">account.move</field>
            <field name="inherit_id" ref="account.view_move_form"/>
            <field name="arch" type="xml">

                <!-- Add Delivery Address after Bill Reference field (ref) -->
                <field name="ref" position="after">
                    <field
                        name="delivery_address_id"
                        string="Delivery Address"
                        invisible="move_type not in ('in_invoice', 'in_refund', 'in_receipt')"
                        domain="[('parent_id', '=', current_company_id), ('type', '=', 'delivery')]"
                        context="{'show_address': 1, 'default_type': 'delivery', 'default_parent_id': current_company_id}"
                        options="{'no_create': False}"
                        readonly="state != 'draft'"
                        force_save="1"
                    />
                </field>

                <!-- Add new fields after Auto-Complete field -->
                <xpath expr="//field[@name='purchase_vendor_bill_id']" position="after">
                    <field name="po_number"
                        invisible="move_type not in ('in_invoice', 'in_refund', 'in_receipt')"
                        domain="[('partner_id', '=', partner_id), ('state', 'in', ['purchase', 'done'])]"
                        options="{'no_create': True, 'no_open': True}"
                        readonly="state != 'draft'"
                        string="PO Number"
                        force_save="1"/>

                    <field name="goods_receipt_number"
                        invisible="move_type not in ('in_invoice', 'in_refund', 'in_receipt')"
                        domain="[('partner_id', '=', partner_id), ('picking_type_id.code', '=', 'incoming'), ('state', '=', 'done')]"
                        options="{'no_create': True, 'no_open': True}"
                        readonly="state != 'draft'"
                        string="Goods Receipt (GR)"
                        force_save="1"/>

                    <field name="awb_number"
                        invisible="move_type not in ('in_invoice', 'in_refund', 'in_receipt')"
                        readonly="state != 'draft'"
                        string="Shipping Ref#"
                        force_save="1"/>

                    <!-- Deliver To field -->
                    <field name="deliver_to"
                        invisible="move_type not in ('in_invoice', 'in_refund', 'in_receipt')"
                        domain="[('code', '=', 'incoming'), ('warehouse_id.company_id', '=', company_id)]"
                        options="{'no_create': True, 'no_open': True}"
                        readonly="state != 'draft'"
                        string="Deliver To"
                        force_save="1"/>

                    <!-- Buyer field -->
                    <field name="buyer_id"
                        invisible="move_type not in ('in_invoice', 'in_refund', 'in_receipt')"
                        domain="[('share', '=', False)]"
                        options="{'no_create': True, 'no_open': True}"
                        readonly="state != 'draft'"
                        string="Buyer"
                        force_save="1"/>
                </xpath>

                <!-- =========================================================
                     FIX 1: Hide the original "1 SAR = 0.266667 USD" display
                     and replace with "1 USD = 3.750000 SAR"
                     Target: the specific currency_conversion_div in header_right_group
                     ========================================================= -->
                <xpath expr="//div[@name='currency_conversion_div']" position="replace">
                    <div name="currency_conversion_div" class="d-flex gap-1 text-muted"
                         invisible="currency_id == company_currency_id">
                        <!-- Our custom label: "1 USD = 3.750000 SAR" -->
                        <field name="currency_rate_label"
                            invisible="currency_id == company_currency_id"
                            readonly="1"
                            nolabel="1"
                            widget="char"
                        />
                        <!-- Hidden fields needed for compute -->
                        <field name="currency_rate_display" invisible="1"/>
                    </div>
                </xpath>

                <!-- =========================================================
                     FIX 2: Show total in company currency (SAR) below
                     the USD total — like PO form
                     Inject after tax_totals inside oe_subtotal_footer group
                     ========================================================= -->
                <xpath expr="//field[@name='tax_totals']" position="after">
                    <field
                        name="amount_total_in_company_currency"
                        nolabel="1"
                        widget="monetary"
                        options="{'currency_field': 'company_currency_id'}"
                        readonly="1"
                        class="text-muted fst-italic text-end"
                        invisible="currency_id == company_currency_id or move_type not in ('in_invoice', 'in_refund', 'in_receipt', 'out_invoice', 'out_refund', 'out_receipt')"
                        colspan="2"
                    />
                </xpath>

            </field>
        </record>

    </data>
</odoo>














