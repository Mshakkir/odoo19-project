<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <!-- Inherit the account payment form view -->
        <record id="view_account_payment_form_custom" model="ir.ui.view">
            <field name="name">account.payment.form.custom</field>
            <field name="model">account.payment</field>
            <field name="inherit_id" ref="account.view_account_payment_form"/>
            <field name="arch" type="xml">

                <!-- Rename the existing memo field to "Payment Reference" -->
                <xpath expr="//field[@name='memo']" position="attributes">
                    <attribute name="string">Payment Reference</attribute>
                </xpath>

                <!--
                    Make the amount field use the currently selected currency_id
                    dynamically (this ensures the currency symbol next to the
                    amount updates as soon as partner_id changes via onchange).
                -->
                <xpath expr="//field[@name='amount']" position="attributes">
                    <attribute name="options">{'currency_field': 'currency_id'}</attribute>
                </xpath>

                <!-- Add manual exchange rate toggle + rate field after currency_id -->
                <xpath expr="//field[@name='currency_id']" position="after">
                    <field name="active_manual_currency_rate"
                           widget="boolean_toggle"
                           attrs="{'invisible': [('currency_id', '=', False)]}"/>
                    <field name="manual_currency_exchange_rate"
                           string="Exchange Rate"
                           attrs="{
                               'invisible': ['|',
                                   ('active_manual_currency_rate', '=', False),
                                   ('currency_id', '=', False)
                               ],
                               'required': [
                                   ('active_manual_currency_rate', '=', True),
                                   ('currency_id', '!=', False)
                               ]
                           }"
                           widget="monetary"
                           options="{'currency_field': 'currency_id', 'field_digits': True}"
                    />
                </xpath>

                <!-- Add new memo field and advance payment checkbox after partner_bank_id -->
                <xpath expr="//group[@name='group2']/field[@name='partner_bank_id'][last()]" position="after">
                    <field name="memo_new" placeholder="Add additional notes here..."/>
                    <field name="is_advance_payment"/>
                </xpath>

            </field>
        </record>
    </data>
</odoo>










